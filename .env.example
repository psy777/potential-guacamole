# Copy this file to `.env` and fill in what you need. Everything is optional
# except APP_SECRET — features light up as you add the matching keys.

# --- App -------------------------------------------------------------------
# A long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=change-me-to-a-long-random-string

# Public base URL of this app. Used to build payment return + webhook URLs.
APP_URL=http://localhost:3000

# Where the SQLite database + uploaded files are stored (defaults to ./data).
# FIRECOAST_DATA_DIR=./data

# How often (ms) to poll Stripe/Square/DocuSeal for status changes.
# POLL_INTERVAL_MS=60000

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=
# Must be an address on a domain you've verified in Resend.
EMAIL_FROM="Your Business <orders@yourdomain.com>"

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=
# Only needed if you expose /api/webhooks/stripe publicly (otherwise polling handles it).
STRIPE_WEBHOOK_SECRET=

# --- Square ----------------------------------------------------------------
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# "sandbox" while testing, "production" when live.
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=

# --- DocuSeal --------------------------------------------------------------
# Hosted: https://api.docuseal.com  ·  Self-hosted: http://localhost:3001
DOCUSEAL_API_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=
DOCUSEAL_TEMPLATE_ID=
DOCUSEAL_WEBHOOK_SECRET=
